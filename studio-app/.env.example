# Copy to .env and fill in real values. Never commit .env.

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- SAM.gov ---
SAM_API_KEY=

# --- Partner monitor cron auth ---
# Shared secret the cron caller (GitHub Actions, Supabase Edge Function,
# or curl) must include as the X-Cron-Token header. Leave blank in dev
# to accept any caller; set in prod to lock down /webhooks/sam.
PARTNER_MONITOR_TOKEN=

# --- Gmail MCP ---
GMAIL_MCP_URL=
GMAIL_MCP_TOKEN=

# --- Stripe (invoicing + Blanks checkout) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Supabase JWT verification (optional but recommended) ---
SUPABASE_JWT_SECRET=

# --- Blanks fulfillment ---
# When set to "1", blanks_fulfillment SENDS supplier POs instead of just drafting.
BLANKS_AUTO_SEND=
# Reply-to / from-address used in supplier PO emails + comms_log audit rows.
AMENITY_OPS_EMAIL=ops@amenity.studio

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
